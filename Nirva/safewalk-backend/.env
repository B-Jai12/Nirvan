# ──────────────────────────────────────────────
# SafeWalk Backend — Environment Variables
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# ── Google Gemini ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
AUDIO_CONFIDENCE_THRESHOLD=0.65

# ── Groq Models ────────────────────────────────
GROQ_API_KEY=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
GROQ_MODEL_LOCATION=llama-3.1-8b-instant
GROQ_MODEL_FILTER=llama-3.3-70b-versatile
COMBINED_CONFIDENCE_THRESHOLD=0.70

# ── Fast2SMS (SMS Alerts) ──────────────────────
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ── EmailJS (Email Alerts) ─────────────────────
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ── Emergency Contacts ─────────────────────────
EMERGENCY_PHONE_NUMBERS=+919876543210,+919123456789
EMERGENCY_EMAILS=guardian@example.com,contact@example.com

# ── Emergency Response (Twilio) ─────────────────
TWILIO_ACCOUNT_SID=AC25748f2a6a72ab53bceb0f9bbcc6ac3c
TWILIO_AUTH_TOKEN=ee244ecc83d65217ccfd2d79e3e77385
TWILIO_FROM_NUMBER=+13613219011
EMERGENCY_CONTACT_NUMBER=+919121032468

# ── App ────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
